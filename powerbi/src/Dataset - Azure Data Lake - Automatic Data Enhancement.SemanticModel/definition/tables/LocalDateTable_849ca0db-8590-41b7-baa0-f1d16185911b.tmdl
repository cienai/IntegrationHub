	partition LocalDateTable_849ca0db-8590-41b7-baa0-f1d16185911b = calculated
		mode: import
		source = VAR _minDate = MIN('open_pipeline'[trueai_act_last_eng]) VAR _maxDate = MAX('open_pipeline'[trueai_act_last_eng]) VAR _start = COALESCE(DATE(YEAR(_minDate), 1, 1), DATE(2015, 1, 1)) VAR _end = COALESCE(DATE(YEAR(_maxDate), 12, 31), DATE(2015, 12, 31)) RETURN CALENDAR(MIN(_start, _end), MAX(_start, _end))

	annotation __PBI_LocalDateTable = true

