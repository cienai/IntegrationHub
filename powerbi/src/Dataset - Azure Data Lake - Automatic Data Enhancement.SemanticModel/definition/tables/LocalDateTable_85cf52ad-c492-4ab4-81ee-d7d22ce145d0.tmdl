	partition LocalDateTable_85cf52ad-c492-4ab4-81ee-d7d22ce145d0 = calculated
		mode: import
		source = VAR _minDate = MIN('open_pipeline'[_sys_filt_start_date]) VAR _maxDate = MAX('open_pipeline'[_sys_filt_start_date]) VAR _start = COALESCE(DATE(YEAR(_minDate), 1, 1), DATE(2015, 1, 1)) VAR _end = COALESCE(DATE(YEAR(_maxDate), 12, 31), DATE(2015, 12, 31)) RETURN CALENDAR(MIN(_start, _end), MAX(_start, _end))

	annotation __PBI_LocalDateTable = true

