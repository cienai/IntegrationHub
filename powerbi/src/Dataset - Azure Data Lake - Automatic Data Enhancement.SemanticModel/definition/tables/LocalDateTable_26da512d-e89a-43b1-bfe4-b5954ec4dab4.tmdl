	partition LocalDateTable_26da512d-e89a-43b1-bfe4-b5954ec4dab4 = calculated
		mode: import
		source = VAR _minDate = MIN('open_pipeline'[trueai_last_eng_act]) VAR _maxDate = MAX('open_pipeline'[trueai_last_eng_act]) VAR _start = COALESCE(DATE(YEAR(_minDate), 1, 1), DATE(2015, 1, 1)) VAR _end = COALESCE(DATE(YEAR(_maxDate), 12, 31), DATE(2015, 12, 31)) RETURN CALENDAR(MIN(_start, _end), MAX(_start, _end))

	annotation __PBI_LocalDateTable = true

