	partition LocalDateTable_9011b70d-1ddf-4dc7-893e-3b39d67cea44 = calculated
		mode: import
		source = VAR _minDate = MIN('open_pipeline'[crm_created_on]) VAR _maxDate = MAX('open_pipeline'[crm_created_on]) VAR _start = COALESCE(DATE(YEAR(_minDate), 1, 1), DATE(2015, 1, 1)) VAR _end = COALESCE(DATE(YEAR(_maxDate), 12, 31), DATE(2015, 12, 31)) RETURN CALENDAR(MIN(_start, _end), MAX(_start, _end))

	annotation __PBI_LocalDateTable = true

