	partition LocalDateTable_1d87fd13-8c8f-4c0d-a23e-9e4897d76188 = calculated
		mode: import
		source = VAR _minDate = MIN('open_pipeline'[trueai_init_close_date]) VAR _maxDate = MAX('open_pipeline'[trueai_init_close_date]) VAR _start = COALESCE(DATE(YEAR(_minDate), 1, 1), DATE(2015, 1, 1)) VAR _end = COALESCE(DATE(YEAR(_maxDate), 12, 31), DATE(2015, 12, 31)) RETURN CALENDAR(MIN(_start, _end), MAX(_start, _end))

	annotation __PBI_LocalDateTable = true

