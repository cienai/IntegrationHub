	/// Measure meas.avg_opp_won_amt.
	/// Purpose: Compute the measure result from the DAX expression and current filter context.
	/// Calculation Logic: See DAX expression.
	/// Dynamic Behavior: See DAX expression.
	/// Format/Type: \$#,0.###############;(\$#,0.###############);\$#,0.###############
	measure 'meas.avg_opp_won_amt' =
			
			var _total = [meas.ssr_history_won_amt]         // get the won amt
			var reps_count = [meas.data_logs_user_count_all]            // total rep count
			var res = DIVIDE( _total, reps_count)            // GET THE avg by reps
			RETURN
			res
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: _average
		lineageTag: c170d19c-9d4d-45f2-ac5d-27a5f8e201d9

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// Measure meas.ssr_history_avg_generated_pipeline_amt.
	/// Purpose: Compute the measure result from the DAX expression and current filter context.
	/// Calculation Logic: See DAX expression.
	/// Dynamic Behavior: See DAX expression.
	/// Format/Type: \$#,0.###############;(\$#,0.###############);\$#,0.###############
	measure 'meas.ssr_history_avg_generated_pipeline_amt' =
			
			
			var _total_amt  = [meas.ssr_history_generated_pipeline_amt]             // get the generated pipeline amt
			var reps_count = [meas.data_logs_user_count_all]        // get total reps count
			var res = DIVIDE(
			    _total_amt, reps_count,0
			)
			RETURN
			res+0
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: _average
