	/// Format/Type: Unspecified
	measure 'meas.performance_metric_value_formatted' =
			
			VAR _valid1 =
			    HASONEVALUE(metadata_performance_metrics[sys_doc_id])
			
			VAR _valid2 =
			    HASONEVALUE(metadata_performance_metrics_secondary[sys_doc_id])
			
			VAR _id =
			    SELECTEDVALUE(metadata_performance_metrics[sys_doc_id])
			
			VAR _measureToReturn =
			    SWITCH(
			        TRUE(),
			
			        /* Revenue Type Metrics */
			        _id = "rev01", [meas.opp_nnb_amt],
			        _id = "rev02", [meas.opp_cross_sale_amt],
			        _id = "rev03", [meas.opp_downgrade_amt],
			        _id = "rev04", [meas.opp_renewal_amt],
			        _id = "rev05", [meas.opp_arr_amt],
			        _id = "rev06", [meas.opp_nd_amt],
			        _id = "rev07", [meas.opp_one_time_amt],
			        _id = "rev08", [meas.opp_expansion_amt],
			        _id = "rev09", [meas.opp_mrr_amt],
			        _id = "rev10", [meas.opps_non_nnb_amt],
			
			        /* Existing Sales Metrics */
			        _id = "sal01", [meas.ssr_history_won_amt],
			        _id = "sal02", [meas.total_opps_count],
			        _id = "sal03", [meas.trueai_potential_acv_per_step_avg],
			        _id = "sal04", [meas.ssr_history_win_rate],
			        _id = "sal05", [meas.total_opps_count],
			
			        /* Pipeline Metrics */
			        _id = "pip01", [meas.pipeline_amt_sum],
			        _id = "pip03", [meas.ssr_history_mgmt_pipeline_count],
			        _id = "pip04", [meas.open_pipeline_avg_days_in_stage],
			
			        /* Activity Metrics */
			        _id = "act01", [meas.stkhlds_all_act_count],
			        _id = "act02", [meas.stkhlds_all_act_email_count],
			        _id = "act03", [meas.stkhlds_all_act_meeting_count],
			        _id = "act04", [meas.ssr_history_duration_hrs],
			
			        BLANK()
			    )
			
			RETURN
			IF(
			    NOT (_valid1 && _valid2),
			    BLANK(),
			    COALESCE(_measureToReturn,0)
			)
		lineageTag: bd190e07-9c43-45a0-9200-f41bfd650dcf

		formatStringDefinition =
				VAR _format =
				    SELECTEDVALUE(metadata_performance_metrics[metric_format], "")
				
				VAR v =
				    ABS(SELECTEDMEASURE())
				
				VAR _txt =
				    SWITCH(
				        TRUE(),
				        ISBLANK(SELECTEDMEASURE()), "",
				        v = 0, "",
				
				        /* Percent stored as 0–1 */
				        _format = "#,0.0"" %""" && v <= 1,
				            FORMAT(v * 100, IF(MOD(v * 100, 1) = 0, "0", "0.0")) & "%",
				
				        /* Percent stored as 0–100 */
				        _format = "#,0.0"" %""",
				            FORMAT(v, IF(MOD(v, 1) = 0, "0", "0.0")) & "%",
				
				        /* Days */
				        _format = "#,0"" days""",
				            FORMAT(v, "0") & " days",
				
				        /* Hours */
				        _format = "#,0.0"" hrs""",
				            FORMAT(v, "0.0") & " hrs",
				
				        /* Currency */
				        _format = "Currency" && v >= 1000000,
				            FORMAT(v / 1000000, IF(MOD(v / 1000000, 1) = 0, "0", "0.0")) & "M",
				
				        _format = "Currency" && v >= 1000,
				            FORMAT(v / 1000, IF(MOD(v / 1000, 1) = 0, "0", "0.0")) & "K",
				
				        _format = "Currency",
				            FORMAT(v, "#,##0"),
				
				        /* Counts / integers */
				        _format = "#,0" && v >= 1000000,
				            FORMAT(v / 1000000, IF(MOD(v / 1000000, 1) = 0, "0", "0.0")) & "M",
				
				        _format = "#,0" && v >= 1000,
				            FORMAT(v / 1000, IF(MOD(v / 1000, 1) = 0, "0", "0.0")) & "K",
				
				        _format = "#,0",
				            FORMAT(v, "#,##0"),
				
				        /* Fallback */
				        FORMAT(v, "#,##0.0")
				    )
				
				RETURN
				"'" & _txt & "'"

