	measure 'meas.is_same_group_role_peer' =
			
			VAR _selectedRole =
			    CALCULATE(
			        SELECTEDVALUE(users[trueai_user_role_alias]),
			        ALLSELECTED(users[trueai_full_name])
			    )
			
			VAR _selectedGroup =
			    CALCULATE(
			        SELECTEDVALUE(users[trueai_group]),
			        ALLSELECTED(users[trueai_full_name])
			    )
			
			VAR _currentRole =
			    SELECTEDVALUE(users[trueai_user_role_alias])
			
			VAR _currentGroup =
			    SELECTEDVALUE(users[trueai_group])
			
			RETURN
			IF(
			    NOT ISBLANK(_selectedRole) &&
			    NOT ISBLANK(_selectedGroup) &&
			    _currentRole = _selectedRole &&
			    _currentGroup = _selectedGroup,
			    1,
			    0
			)
		formatString: 0
		lineageTag: f8dce238-64d4-4286-8f03-f5a0230e64f8

