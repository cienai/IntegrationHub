	/// Measure meas.performance_correlation_metric1_vs_metric2.
	/// Purpose: Compute the measure result from the DAX expression and current filter context.
	/// Calculation Logic: See DAX expression.
	/// Dynamic Behavior: See DAX expression.
	/// Format/Type: Unspecified
	measure 'meas.performance_correlation_metric1_vs_metric2' = ```
			
			-- Based on Pearson Correlation Coefficient
			-- 1. Create the unified Virtual Table with both Metrics
			VAR _RepTable = 
			    SUMMARIZECOLUMNS(
			        users[trueai_full_name],
			        "x", [meas.performance_metric_value_formatted], -- Slicer 1
			        "y", [meas.performance_metric_value_secondary]  -- Slicer 2
			    )
			
			-- 2. Filter out Blanks (Correlation requires pairs of numbers)
			VAR _CleanTable = 
			    FILTER( _RepTable, NOT( ISBLANK([x]) || ISBLANK([y]) ) )
			
			-- 3. The Math Steps (Pearson Correlation)
			VAR _n      = COUNTROWS(_CleanTable)
			VAR _avgX   = AVERAGEX(_CleanTable, [x])
			VAR _avgY   = AVERAGEX(_CleanTable, [y])
			
			VAR _sumXY  = SUMX(_CleanTable, ([x] - _avgX) * ([y] - _avgY))
			VAR _sumX2  = SUMX(_CleanTable, POWER([x] - _avgX, 2))
			VAR _sumY2  = SUMX(_CleanTable, POWER([y] - _avgY, 2))
			
			VAR _denom  = SQRT(_sumX2 * _sumY2)
			
			RETURN
			    -- Return blank if not enough data (need at least 2 reps)
			    IF( _n < 2 || _denom = 0, BLANK(), DIVIDE(_sumXY, _denom) )
			```
		lineageTag: 0829e423-3078-4b1d-abdc-b4ee30fad4e7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Measure meas.rank_reps_by_selected_sorting.
