	/// Measure meas.rep_overview_metric_1.
	/// Purpose: Compute the measure result from the DAX expression and current filter context.
	/// Calculation Logic: See DAX expression.
	/// Dynamic Behavior: See DAX expression.
	/// Format/Type: Unspecified
	measure 'meas.rep_overview_metric_1' = ```
			
			VAR _selected_metric =
			    CALCULATE (
			        SELECTEDVALUE ( performance_metric_1[_sys_doc_id] ) 
			    )
			VAR _formatString = MAX ( companies_history[col.currency_format] )
			VAR res =
			    SWITCH (
			        _selected_metric,
			        "sal1", FORMAT ( [meas.ssr_history_won_amt] / 1000, _formatString & "#,##0" ) & "K",
			        "sal2", FORMAT ( [meas.ssr_history_win_rate], "0.0%" ),
			        "sal3", [meas.exp_rpts_all_won_deals],
			        "sal4", FORMAT ( [meas.ssr_history_won_amt_new_logo] / 1000, _formatString & "#,##0" ) & "K",
			        "sal7", FORMAT ( [meas.ssr_history_won_amt_existing_customer_selling] / 1000, _formatString & "#,##0" ) & "K",
			        "pip1", FORMAT ( [meas.ssr_history_generated_pipeline_amt] / 1000, _formatString & "#,##0" ) & "K",
			        "pip2", FORMAT ( [meas.ssr_history_pipeline_amt] / 1000, _formatString & "#,##0" ) & "K", 
			        "pip4", FORMAT ( [meas.open_pipeline_booking_amt] / 1000, _formatString & "#,##0" ) & "K",
			        "pip5", FORMAT ( [meas.ssr_history_adj_pipeline_amt] / 1000, _formatString & "#,##0" ) & "K",
			        "pip6", FORMAT ( [meas.ssr_history_open_pipeline_success_rate], "0.0%" ),
			        "pip7", [meas.open_pipeline_count_id],
			        "pip8", [meas.ssr_history_mgmt_leads_gen_count],
			        "act1", FORMAT ( [meas.users_history_avg_ci_act_capt_lvl], "0.0%" ),
			        "act2", [meas.stkhlds_all_act_count],
			        "act3", FORMAT ( [meas.ssr_history_duration_hrs], "#,##0"" hrs""" ),
			        "act4", FORMAT ( [meas.ssr_history_all_eng_duration_hrs], "#,##0"" hrs""" ),
			        "act5", [meas.stkhlds_all_act_email_count],
			        "act6", [meas.stkhlds_all_act_phone_calls],
			        "act7", [meas.stkhlds_all_act_meeting_count],
			         "act9", [meas.stkhlds_all_act_social_media_count],
			        "act10", [meas.stkhlds_all_act_nd_count],
			        "act11", [meas.users_activities_prospecting_count],
			        "act12", [meas.users_activities_new_logo_count],
			        "act13", [meas.users_activities_post_sales_count],
			        "act14", [meas.users_activities_existing_customer_count],
			        "act15", [meas.users_activities_internal_count],
			        "act16", FORMAT ( [meas.ssr_history_duration_hrs_prospecting], "#,##0"" hrs""" ),
			        "act17", FORMAT ( [meas.ssr_history_duration_hrs_new_logo], "#,##0"" hrs""" ),
			        "act18", FORMAT ( [meas.ssr_history_duration_hrs_post_sales], "#,##0"" hrs""" ),
			        "act19", FORMAT ( [meas.ssr_history_duration_hrs_existing_customer_selling], "#,##0"" hrs""" )
			    )
			RETURN
			    res
			```
		lineageTag: e96ea275-ffef-45a9-ba43-89a6b054cba0

