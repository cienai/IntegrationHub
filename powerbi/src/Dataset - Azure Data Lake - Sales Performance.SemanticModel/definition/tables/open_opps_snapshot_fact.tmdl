	partition open_opps_snapshot_fact = m
		mode: import
		source =
				let
				    NormalizeText = (value as nullable text, fallback as text) as text =>
				        if value = null or Text.Trim(value) = "" then fallback else value,
				    NormalizeIntervals = (oppRows as table) as table =>
				        let
				            OppSorted = Table.Sort(
				                oppRows,
				                {
				                    {"source_valid_from", Order.Ascending},
				                    {"_sys_filt_end_date", Order.Ascending},
				                    {"source_sort_num", Order.Descending},
				                    {"trueai_sort_id", Order.Descending},
				                    {"_sys_doc_id", Order.Descending}
				                }
				            ),
				            OppIndexed = Table.AddIndexColumn(OppSorted, "interval_index", 0, 1, Int64.Type),
				            WithValidFrom = Table.AddColumn(
				                OppIndexed,
				                "valid_from",
				                each
				                    let
				                        SourceValidFrom = [source_valid_from],
				                        PrevValidTo = if [interval_index] = 0 then null else OppIndexed{[interval_index] - 1}[_sys_filt_end_date]
				                    in
				                        if SourceValidFrom = null then PrevValidTo
				                        else if PrevValidTo <> null and PrevValidTo > SourceValidFrom then PrevValidTo
				                        else SourceValidFrom,
				                type date
				            ),
				            RemovedIndex = Table.RemoveColumns(WithValidFrom, {"interval_index"})
				        in
				            RemovedIndex,
				    OpenPipelineRaw = getDBTable("open_pipeline"),
				    OpenPipelineTyped = Table.TransformColumnTypes(
				        OpenPipelineRaw,
				        {
				            {"_sys_doc_id", type text},
				            {"_sys_filt_end_date", type date},
				            {"_sys_filt_start_date", type date},
				            {"trueai_can_be_excluded", type logical},
				            {"crm_close_date", type datetime},
				            {"crm_created_on", type datetime},
				            {"crm_opp_id", type text},
				            {"crm_stage_name", type text},
				            {"trueai_act_count", Int64.Type},
				            {"trueai_act_dur", type number},
				            {"trueai_act_last_eng", type datetime},
				            {"trueai_booking_amt", type number},
				            {"trueai_current_prob_of_win", type number},
				            {"trueai_init_close_date", type datetime},
				            {"trueai_owner_id", type text},
				            {"trueai_pace_score", type number},
				            {"trueai_pipeline_name", type text},
				            {"trueai_sort_id", type text},
				            {"trueai_stage", type text},
				            {"trueai_stage_name", type text}
				        }
				    ),
				    OpenPipelineFiltered = Table.SelectRows(
				        OpenPipelineTyped,
				        each [crm_opp_id] <> null
				            and Text.Trim([crm_opp_id]) <> ""
				            and [_sys_filt_end_date] <> null
				    ),
				    WithSourceSortNum = Table.AddColumn(
				        OpenPipelineFiltered,
				        "source_sort_num",
				        each try Int64.From([trueai_sort_id]) otherwise null,
				        Int64.Type
				    ),
				    WithSourceValidFrom = Table.AddColumn(
				        WithSourceSortNum,
				        "source_valid_from",
				        each if [_sys_filt_start_date] <> null then [_sys_filt_start_date] else if [crm_created_on] <> null then Date.From([crm_created_on]) else null,
				        type date
				    ),
				    SortedIntervals = Table.Sort(
				        WithSourceValidFrom,
				        {
				            {"crm_opp_id", Order.Ascending},
				            {"source_valid_from", Order.Ascending},
				            {"_sys_filt_end_date", Order.Ascending},
				            {"source_sort_num", Order.Descending},
				            {"trueai_sort_id", Order.Descending},
				            {"_sys_doc_id", Order.Descending}
				        }
				    ),
				    BufferedIntervals = Table.Buffer(SortedIntervals),
				    CanonicalIntervals = Table.Distinct(
				        BufferedIntervals,
				        {"crm_opp_id", "source_valid_from", "_sys_filt_end_date"}
				    ),
				    GroupedByOpp = Table.Group(
				        CanonicalIntervals,
				        {"crm_opp_id"},
				        {{"snapshot_rows", each NormalizeIntervals(_), type table}}
				    ),
				    ExpandedIntervals = Table.ExpandTableColumn(
				        GroupedByOpp,
				        "snapshot_rows",
				        {
				            "_sys_doc_id",
				            "_sys_filt_end_date",
				            "_sys_filt_start_date",
				            "trueai_can_be_excluded",
				            "crm_close_date",
				            "crm_created_on",
				            "crm_stage_name",
				            "source_sort_num",
				            "source_valid_from",
				            "trueai_act_count",
				            "trueai_act_dur",
				            "trueai_act_last_eng",
				            "trueai_booking_amt",
				            "trueai_current_prob_of_win",
				            "trueai_init_close_date",
				            "trueai_owner_id",
				            "trueai_pace_score",
				            "trueai_pipeline_name",
				            "trueai_sort_id",
				            "trueai_stage",
				            "trueai_stage_name",
				            "valid_from"
				        },
				        {
				            "_sys_doc_id",
				            "_sys_filt_end_date",
				            "_sys_filt_start_date",
				            "trueai_can_be_excluded",
				            "crm_close_date",
				            "crm_created_on",
				            "crm_stage_name",
				            "source_sort_num",
				            "source_valid_from",
				            "trueai_act_count",
				            "trueai_act_dur",
				            "trueai_act_last_eng",
				            "trueai_booking_amt",
				            "trueai_current_prob_of_win",
				            "trueai_init_close_date",
				            "trueai_owner_id",
				            "trueai_pace_score",
				            "trueai_pipeline_name",
				            "trueai_sort_id",
				            "trueai_stage",
				            "trueai_stage_name",
				            "valid_from"
				        }
				    ),
				    ValidIntervals = Table.SelectRows(
				        ExpandedIntervals,
				        each [valid_from] <> null and [valid_from] < [_sys_filt_end_date]
				    ),
				    OppsRaw = getDBTable("opps"),
				    OppsTyped = Table.TransformColumnTypes(
				        OppsRaw,
				        {
				            {"_sys_doc_id", type text},
				            {"_sys_ssr_id", type text},
				            {"_sys_filt_end_date", type date},
				            {"_sys_filt_start_date", type date},
				            {"_sys_is_active", type logical},
				            {"crm_name", type text},
				            {"crm_is_closed", type logical},
				            {"crm_stage_name", type text},
				            {"trueai_stage", type text},
				            {"trueai_stage_name", type text},
				            {"trueai_propensity", type text},
				            {"trueai_propensity_num", Int64.Type},
				            {"trueai_sale_type", type text},
				            {"trueai_test", type logical}
				        }
				    ),
				    OppsFiltered = Table.SelectRows(OppsTyped, each [_sys_doc_id] <> null and Text.Trim([_sys_doc_id]) <> ""),
				    WithOppRows = Table.NestedJoin(
				        ValidIntervals,
				        {"crm_opp_id"},
				        OppsFiltered,
				        {"_sys_doc_id"},
				        "opp_rows",
				        JoinKind.LeftOuter
				    ),
				    WithOppRecord = Table.AddColumn(
				        WithOppRows,
				        "opp_record",
				        each
				            let
				                OppRows = [opp_rows],
				                TargetDate = [valid_from],
				                MatchingRows =
				                    if OppRows = null then #table({}, {})
				                    else Table.SelectRows(
				                        OppRows,
				                        each ([_sys_filt_start_date] = null or [_sys_filt_start_date] <= TargetDate)
				                            and ([_sys_filt_end_date] = null or [_sys_filt_end_date] > TargetDate)
				                    ),
				                RankedRows = MatchingRows,
				                SortedRows =
				                    if RankedRows = null then #table({}, {})
				                    else Table.Sort(
				                        RankedRows,
				                        {
				                            {"_sys_filt_end_date", Order.Descending},
				                            {"_sys_filt_start_date", Order.Descending},
				                            {"_sys_doc_id", Order.Descending}
				                        }
				                    ),
				                RawRecord =
				                    if SortedRows = null or Table.RowCount(SortedRows) = 0 then null else SortedRows{0},
				                SafeRecord =
				                    if RawRecord = null then
				                        [
				                            _sys_doc_id = null,
				                            _sys_ssr_id = null,
				                            _sys_is_active = null,
				                            crm_name = null,
				                            crm_is_closed = null,
				                            crm_stage_name = null,
				                            trueai_stage = null,
				                            trueai_stage_name = null,
				                            trueai_propensity = null,
				                            trueai_propensity_num = null,
				                            trueai_sale_type = null,
				                            trueai_test = null
				                        ]
				                    else
				                        Record.SelectFields(
				                            RawRecord,
				                            {
				                                "_sys_doc_id",
				                                "_sys_ssr_id",
				                                "_sys_is_active",
				                                "crm_name",
				                                "crm_is_closed",
				                                "crm_stage_name",
				                                "trueai_stage",
				                                "trueai_stage_name",
				                                "trueai_propensity",
				                                "trueai_propensity_num",
				                                "trueai_sale_type",
				                                "trueai_test"
				                            },
				                            MissingField.UseNull
				                        )
				            in
				                SafeRecord,
				        type record
				    ),
				    ExpandedOppRecord = Table.ExpandRecordColumn(
				        WithOppRecord,
				        "opp_record",
				        {"_sys_doc_id", "_sys_ssr_id", "_sys_is_active", "crm_name", "crm_is_closed", "crm_stage_name", "trueai_stage", "trueai_stage_name", "trueai_propensity", "trueai_propensity_num", "trueai_sale_type", "trueai_test"},
				        {"matched_opp_id", "_sys_ssr_id", "matched_opp_is_active", "opp_name", "matched_opp_is_closed", "matched_opp_crm_stage_name", "matched_opp_trueai_stage", "matched_opp_trueai_stage_name", "trueai_propensity", "trueai_propensity_num", "trueai_sale_type", "matched_opp_is_test"}
				    ),
				    WithCrmExportEligibility = Table.AddColumn(
				        ExpandedOppRecord,
				        "crm_export_eligible",
				        each [matched_opp_id] <> null
				            and [matched_opp_is_closed] = false
				            and ([matched_opp_is_active] = null or [matched_opp_is_active] = true)
				            and ([matched_opp_is_test] = null or [matched_opp_is_test] = false)
				            and ([trueai_can_be_excluded] = null or [trueai_can_be_excluded] = false)
				            and [opp_name] <> null
				            and Text.Trim([opp_name]) <> ""
				            and not Text.Contains(Text.Lower([opp_name]), "test"),
				        type logical
				    ),
				    WithStageFallback = Table.TransformColumns(
				        Table.AddColumn(
				            Table.AddColumn(
				                Table.AddColumn(
				                    WithCrmExportEligibility,
				                    "trueai_stage_resolved",
				                    each
				                        let
				                            PipelineStage = [trueai_stage]
				                        in
				                            if PipelineStage <> null and Text.Trim(PipelineStage) <> "" then PipelineStage else [matched_opp_trueai_stage],
				                    type text
				                ),
				                "trueai_stage_name_resolved",
				                each
				                    let
				                        PipelineStageName = [trueai_stage_name]
				                    in
				                        if PipelineStageName <> null and Text.Trim(PipelineStageName) <> "" then PipelineStageName
				                        else if [matched_opp_trueai_stage_name] <> null and Text.Trim([matched_opp_trueai_stage_name]) <> "" then [matched_opp_trueai_stage_name]
				                        else [matched_opp_crm_stage_name],
				                    type text
				            ),
				            "crm_stage_name_resolved",
				            each
				                let
				                    PipelineCrmStageName = [crm_stage_name]
				                in
				                    if PipelineCrmStageName <> null and Text.Trim(PipelineCrmStageName) <> "" then PipelineCrmStageName else [matched_opp_crm_stage_name],
				            type text
				        ),
				        {
				            {"trueai_propensity", each if _ <> null and Text.Trim(_) <> "" then _ else null, type text}
				        }
				    ),
				    CleanedResolvedStageColumns = Table.RemoveColumns(
				        WithStageFallback,
				        {"trueai_stage", "trueai_stage_name", "crm_stage_name"}
				    ),
				    RenamedResolvedStageColumns = Table.RenameColumns(
				        CleanedResolvedStageColumns,
				        {
				            {"trueai_stage_resolved", "trueai_stage"},
				            {"trueai_stage_name_resolved", "trueai_stage_name"},
				            {"crm_stage_name_resolved", "crm_stage_name"}
				        }
				    ),
				    WithOppDefaults =
				        let
				            EnsureTextColumn = (tbl as table, col as text) as table =>
				                if Table.HasColumns(tbl, {col}) then tbl else Table.AddColumn(tbl, col, each null, type text),
				            EnsureIntColumn = (tbl as table, col as text) as table =>
				                if Table.HasColumns(tbl, {col}) then tbl else Table.AddColumn(tbl, col, each null, Int64.Type),
				            WithPropensity = EnsureTextColumn(RenamedResolvedStageColumns, "trueai_propensity"),
				            WithPropensityNum = EnsureIntColumn(WithPropensity, "trueai_propensity_num"),
				            WithSaleType = EnsureTextColumn(WithPropensityNum, "trueai_sale_type"),
				            WithOppName = EnsureTextColumn(WithSaleType, "opp_name"),
				            WithSsrId = EnsureTextColumn(WithOppName, "_sys_ssr_id")
				        in
				            WithSsrId,
				    UsersRaw = getDBTable("users"),
				    UsersTyped = Table.TransformColumnTypes(
				        UsersRaw,
				        {
				            {"_sys_doc_id", type text},
				            {"trueai_full_name", type text},
				            {"trueai_group", type text}
				        }
				    ),
				    UsersDeduped = Table.Distinct(UsersTyped, {"_sys_doc_id"}),
				    WithUsers = Table.NestedJoin(
				        WithOppDefaults,
				        {"trueai_owner_id"},
				        UsersDeduped,
				        {"_sys_doc_id"},
				        "user_rows",
				        JoinKind.LeftOuter
				    ),
				    ExpandedUsers = Table.ExpandTableColumn(
				        WithUsers,
				        "user_rows",
				        {"trueai_full_name", "trueai_group"},
				        {"trueai_full_name", "trueai_group"}
				    ),
				    SsrRaw = getDBTable("ssr"),
				    SsrTyped = Table.TransformColumnTypes(
				        SsrRaw,
				        {
				            {"_sys_doc_id", type text},
				            {"crm_name", type text}
				        }
				    ),
				    SsrDeduped = Table.Distinct(SsrTyped, {"_sys_doc_id"}),
				    WithAccount = Table.NestedJoin(
				        ExpandedUsers,
				        {"_sys_ssr_id"},
				        SsrDeduped,
				        {"_sys_doc_id"},
				        "ssr_rows",
				        JoinKind.LeftOuter
				    ),
				    ExpandedAccount = Table.ExpandTableColumn(
				        WithAccount,
				        "ssr_rows",
				        {"crm_name"},
				        {"account_name"}
				    ),
				    SsrHistoryRaw = getDBTable("ssr_history"),
				    SsrHistoryTyped = Table.TransformColumnTypes(
				        SsrHistoryRaw,
				        {
				            {"entity_opp_id", type text},
				            {"stkhlds_all_contacts_count", Int64.Type}
				        }
				    ),
				    StakeholderCounts = Table.Group(
				        Table.SelectRows(SsrHistoryTyped, each [entity_opp_id] <> null and Text.Trim([entity_opp_id]) <> ""),
				        {"entity_opp_id"},
				        {
				            {"stkhlds_all_contacts_count", each try List.Max(List.RemoveNulls([stkhlds_all_contacts_count])) otherwise null, Int64.Type}
				        }
				    ),
				    WithStakeholders = Table.NestedJoin(
				        ExpandedAccount,
				        {"crm_opp_id"},
				        StakeholderCounts,
				        {"entity_opp_id"},
				        "stakeholder_rows",
				        JoinKind.LeftOuter
				    ),
				    ExpandedStakeholders = Table.ExpandTableColumn(
				        WithStakeholders,
				        "stakeholder_rows",
				        {"stkhlds_all_contacts_count"},
				        {"stkhlds_all_contacts_count"}
				    ),
				    WithNormalizedColumns = Table.TransformColumns(
				        ExpandedStakeholders,
				        {
				            {"trueai_stage", each NormalizeText(_, "Unknown"), type text},
				            {"trueai_stage_name", each NormalizeText(_, "Unknown"), type text},
				            {"crm_stage_name", each NormalizeText(_, "Unknown"), type text},
				            {"trueai_propensity", each NormalizeText(_, "Unknown"), type text},
				            {"trueai_sale_type", each NormalizeText(_, "Unknown"), type text},
				            {"trueai_group", each NormalizeText(_, "Unknown"), type text}
				        }
				    ),
				    WithOppNameFallback = Table.AddColumn(
				        WithNormalizedColumns,
				        "opp_name_resolved",
				        each NormalizeText([opp_name], [crm_opp_id]),
				        type text
				    ),
				    WithAccountNameFallback = Table.AddColumn(
				        WithOppNameFallback,
				        "account_name_resolved",
				        each NormalizeText([account_name], NormalizeText([_sys_ssr_id], [crm_opp_id])),
				        type text
				    ),
				    WithUserNameFallback = Table.AddColumn(
				        WithAccountNameFallback,
				        "trueai_full_name_resolved",
				        each NormalizeText([trueai_full_name], NormalizeText([trueai_owner_id], [crm_opp_id])),
				        type text
				    ),
				    CleanedFallbackColumns = Table.RemoveColumns(
				        WithUserNameFallback,
				        {"opp_name", "account_name", "trueai_full_name"}
				    ),
				    RenamedFallbackColumns = Table.RenameColumns(
				        CleanedFallbackColumns,
				        {
				            {"opp_name_resolved", "opp_name"},
				            {"account_name_resolved", "account_name"},
				            {"trueai_full_name_resolved", "trueai_full_name"}
				        }
				    ),
				    WithDerived = Table.AddColumn(
				        RenamedFallbackColumns,
				        "snapshot_row_id",
				        each [crm_opp_id] & "|" & Date.ToText([valid_from], "yyyy-MM-dd") & "|" & Date.ToText([_sys_filt_end_date], "yyyy-MM-dd") & "|" & [_sys_doc_id],
				        type text
				    ),
				    WithEntityOppId = Table.AddColumn(WithDerived, "entity_opp_id", each [crm_opp_id], type text),
				    WithOppId = Table.AddColumn(WithEntityOppId, "opp_id", each [crm_opp_id], type text),
				    WithAmount = Table.AddColumn(WithOppId, "amount", each [trueai_booking_amt], type number),
				    WithExpectedValue = Table.AddColumn(
				        WithAmount,
				        "expected_value",
				        each if [trueai_booking_amt] = null or [trueai_current_prob_of_win] = null then null else [trueai_booking_amt] * [trueai_current_prob_of_win],
				        type number
				    ),
				    WithDurHours = Table.AddColumn(
				        WithExpectedValue,
				        "act_dur_hours",
				        each if [trueai_act_dur] = null then null else [trueai_act_dur] / 3600,
				        type number
				    ),
				    WithInitialCloseDate = Table.AddColumn(WithDurHours, "initial_close_date", each [trueai_init_close_date], type datetime),
				    WithLastEngDate = Table.AddColumn(WithInitialCloseDate, "trueai_last_eng_act", each [trueai_act_last_eng], type datetime),
				    WithClosedStage = Table.AddColumn(
				        WithLastEngDate,
				        "is_closed_stage",
				        each [trueai_stage] = "Closed Won" or [trueai_stage] = "Closed Lost",
				        type logical
				    ),
				    WithOpenFlag = Table.AddColumn(WithClosedStage, "is_open_as_of_row", each not [is_closed_stage], type logical),
				    WithStatus = Table.AddColumn(WithOpenFlag, "snapshot_status", each if [is_closed_stage] then "Closed" else "Open", type text),
				    WithStageNum = Table.AddColumn(
				        WithStatus,
				        "trueai_stage_num",
				        each
				            if [trueai_stage] = "Early" then 1
				            else if [trueai_stage] = "Mid" then 2
				            else if [trueai_stage] = "Late" then 3
				            else if [trueai_stage] = "Closed Won" then 4
				            else if [trueai_stage] = "Closed Lost" then 5
				            else 6,
				        Int64.Type
				    ),
				    WithPaceBucket = Table.AddColumn(
				        WithStageNum,
				        "pace_score_bucket",
				        each
				            let
				                PaceScore = [trueai_pace_score],
				                PaceBucket = if PaceScore = null then null else Number.Round(PaceScore * 5, 0)
				            in
				                if PaceBucket = null then "Unknown"
				                else if PaceBucket <= 0 then "0 - Static"
				                else if PaceBucket = 1 then "1 - Slow-Moving"
				                else if PaceBucket = 2 then "2 - Progressing"
				                else if PaceBucket = 3 then "3 - Advancing"
				                else if PaceBucket = 4 then "4 - Accelerated"
				                else "5 - Rapid",
				        type text
				    ),
				    WithOwnerName = Table.AddColumn(WithPaceBucket, "owner_name", each [trueai_full_name], type text),
				    WithSellerName = Table.AddColumn(WithOwnerName, "seller_name", each [trueai_full_name], type text),
				    RenamedColumns = Table.RenameColumns(
				        WithSellerName,
				        {
				            {"_sys_doc_id", "source_row_doc_id"},
				            {"source_sort_num", "source_sort_id"},
				            {"_sys_filt_end_date", "valid_to"}
				        }
				    ),
				    SelectedColumns = Table.SelectColumns(
				        RenamedColumns,
				        {
				            "snapshot_row_id",
				            "entity_opp_id",
				            "opp_id",
				            "crm_opp_id",
				            "source_row_doc_id",
				            "source_sort_id",
				            "valid_from",
				            "valid_to",
				            "is_open_as_of_row",
				            "is_closed_stage",
				            "crm_export_eligible",
				            "snapshot_status",
				            "trueai_stage",
				            "trueai_stage_name",
				            "crm_stage_name",
				            "trueai_stage_num",
				            "trueai_propensity",
				            "trueai_propensity_num",
				            "trueai_sale_type",
				            "trueai_pipeline_name",
				            "trueai_can_be_excluded",
				            "opp_name",
				            "account_name",
				            "owner_name",
				            "seller_name",
				            "trueai_group",
				            "trueai_full_name",
				            "amount",
				            "expected_value",
				            "crm_created_on",
				            "crm_close_date",
				            "initial_close_date",
				            "trueai_pace_score",
				            "pace_score_bucket",
				            "trueai_act_count",
				            "act_dur_hours",
				            "trueai_last_eng_act",
				            "stkhlds_all_contacts_count"
				        },
				        MissingField.UseNull
				    ),
				    FinalTyped = Table.TransformColumnTypes(
				        SelectedColumns,
				        {
				            {"snapshot_row_id", type text},
				            {"entity_opp_id", type text},
				            {"opp_id", type text},
				            {"crm_opp_id", type text},
				            {"source_row_doc_id", type text},
				            {"source_sort_id", Int64.Type},
				            {"valid_from", type datetime},
				            {"valid_to", type datetime},
				            {"is_open_as_of_row", type logical},
				            {"is_closed_stage", type logical},
				            {"crm_export_eligible", type logical},
				            {"snapshot_status", type text},
				            {"trueai_stage", type text},
				            {"trueai_stage_name", type text},
				            {"crm_stage_name", type text},
				            {"trueai_stage_num", Int64.Type},
				            {"trueai_propensity", type text},
				            {"trueai_propensity_num", Int64.Type},
				            {"trueai_sale_type", type text},
				            {"trueai_pipeline_name", type text},
				            {"trueai_can_be_excluded", type logical},
				            {"opp_name", type text},
				            {"account_name", type text},
				            {"owner_name", type text},
				            {"seller_name", type text},
				            {"trueai_group", type text},
				            {"trueai_full_name", type text},
				            {"amount", type number},
				            {"expected_value", type number},
				            {"crm_created_on", type datetime},
				            {"crm_close_date", type datetime},
				            {"initial_close_date", type datetime},
				            {"trueai_pace_score", type number},
				            {"pace_score_bucket", type text},
				            {"trueai_act_count", Int64.Type},
				            {"act_dur_hours", type number},
				            {"trueai_last_eng_act", type datetime},
				            {"stkhlds_all_contacts_count", Int64.Type}
				        }
				    )
				in
				    FinalTyped

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

	annotation PBI_Id = 0fef07ce35f948b0b57fd84c2a9a4c0a

