/// Canonical historical snapshot fact for Open Opportunities page visuals.
table open_opps_snapshot_fact
	lineageTag: 1f4ef8a3-8df2-4d6a-9ce0-cf8ef4a4b0ae

	/// Returns 1 when the current snapshot row is valid and open for the selected date.
	measure 'meas.open_opps_snapshot_fact_include' =
			
			VAR sel_date = [meas.cal_end_sel_date]
			VAR drill_opp_id =
			    COALESCE(
			        SELECTEDVALUE(ssr_history[entity_opp_id]),
			        SELECTEDVALUE(opps[_sys_doc_id]),
			        SELECTEDVALUE(open_pipeline[crm_opp_id])
			    )
			VAR current_opp_id = MAX(open_opps_snapshot_fact[entity_opp_id])
			VAR is_closed_stage =
			    MAXX(
			        open_opps_snapshot_fact,
			        IF(open_opps_snapshot_fact[is_closed_stage], 1, 0)
			    )
			VAR is_crm_export_eligible =
			    MAXX(
			        open_opps_snapshot_fact,
			        IF(open_opps_snapshot_fact[crm_export_eligible], 1, 0)
			    )
			RETURN
			IF(
			    MAX(open_opps_snapshot_fact[valid_from]) <= sel_date
			        && MAX(open_opps_snapshot_fact[valid_to]) > sel_date
			        && is_closed_stage = 0
			        && is_crm_export_eligible = 1
			        && (ISBLANK(drill_opp_id) || current_opp_id = drill_opp_id),
			    1,
			    0
			)
		formatString: 0
		displayFolder: _open_opps_snapshot_fact
		lineageTag: 0dbc1028-9bc3-4a91-bd60-6d0f0dd0d8fd

	/// Counts open opportunities from the canonical snapshot fact.
	measure 'meas.open_opps_snapshot_fact_count' =
			
			VAR sel_date = [meas.cal_end_sel_date]
			VAR drill_opp_id =
			    COALESCE(
			        SELECTEDVALUE(ssr_history[entity_opp_id]),
			        SELECTEDVALUE(opps[_sys_doc_id]),
			        SELECTEDVALUE(open_pipeline[crm_opp_id])
			    )
			RETURN
			CALCULATE(
			    DISTINCTCOUNT(open_opps_snapshot_fact[entity_opp_id]),
			    FILTER(
			        open_opps_snapshot_fact,
			        open_opps_snapshot_fact[valid_from] <= sel_date
			            && open_opps_snapshot_fact[valid_to] > sel_date
			            && open_opps_snapshot_fact[is_closed_stage] = FALSE()
			            && open_opps_snapshot_fact[crm_export_eligible] = TRUE()
			            && (ISBLANK(drill_opp_id) || open_opps_snapshot_fact[entity_opp_id] = drill_opp_id)
			    )
			)
		formatString: #,0
		displayFolder: _open_opps_snapshot_fact
		lineageTag: 1dd58db4-c469-48fd-aee0-3b6c3c892f6d

	/// Sums canonical snapshot booking amount.
	measure 'meas.open_opps_snapshot_fact_amount' =
			
			VAR sel_date = [meas.cal_end_sel_date]
			VAR drill_opp_id =
			    COALESCE(
			        SELECTEDVALUE(ssr_history[entity_opp_id]),
			        SELECTEDVALUE(opps[_sys_doc_id]),
			        SELECTEDVALUE(open_pipeline[crm_opp_id])
			    )
			RETURN
			CALCULATE(
			    SUM(open_opps_snapshot_fact[amount]),
			    FILTER(
			        open_opps_snapshot_fact,
			        open_opps_snapshot_fact[valid_from] <= sel_date
			            && open_opps_snapshot_fact[valid_to] > sel_date
			            && open_opps_snapshot_fact[is_closed_stage] = FALSE()
			            && open_opps_snapshot_fact[crm_export_eligible] = TRUE()
			            && (ISBLANK(drill_opp_id) || open_opps_snapshot_fact[entity_opp_id] = drill_opp_id)
			    )
			)
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: _open_opps_snapshot_fact
		lineageTag: 5087c60c-0a2a-44ff-9574-b2cf2078d4cf

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// Compatibility measure for list visuals: pipeline amount on the canonical rowset.
	measure 'meas.open_opps_snapshot_fact_pipeline_amt' = SUM(open_opps_snapshot_fact[amount])
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: _open_opps_snapshot_fact
		lineageTag: d6f8a6a4-9435-4068-a6ec-e00300cebf6d

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// Compatibility measure for list visuals: expected value on the canonical rowset.
	measure 'meas.open_opps_snapshot_fact_expected_value' = SUM(open_opps_snapshot_fact[expected_value])
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: _open_opps_snapshot_fact
		lineageTag: 2952ef4c-c7c6-4870-96bd-89dc7ae04a99

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// Returns the opportunity age as of the selected date.
	measure 'meas.open_opps_snapshot_fact_age_days' =
			
			VAR sel_date = [meas.cal_end_sel_date]
			VAR created_on = MAX(open_opps_snapshot_fact[crm_created_on])
			RETURN
			IF(
			    ISBLANK(created_on),
			    BLANK(),
			    DATEDIFF(DATE(YEAR(created_on), MONTH(created_on), DAY(created_on)), sel_date, DAY)
			)
		formatString: 0
		displayFolder: _open_opps_snapshot_fact
		lineageTag: 2de43d65-045f-4f0d-b86e-a88cbeba353f

	/// Compatibility measure for the initial close date shown in the list.
	measure 'meas.open_opps_snapshot_fact_initial_close_date' = MAX(open_opps_snapshot_fact[initial_close_date])
		formatString: Short Date
		displayFolder: _open_opps_snapshot_fact
		lineageTag: 7290f247-2f74-446d-ad30-052cfa8d490e

	/// Compatibility measure for total activity duration on the canonical rowset.
	measure 'meas.open_opps_snapshot_fact_dur_hrs' = SUM(open_opps_snapshot_fact[act_dur_hours])
		formatString: #,##0.0" hrs"
		displayFolder: _open_opps_snapshot_fact
		lineageTag: 343b49ea-aac2-4d18-bcb7-3af5f1270b10

		annotation PBI_FormatHint = {"isCustom":true}

	/// Compatibility measure for pace score display using the canonical row.
	measure 'meas.open_opps_snapshot_fact_avg_pace_score' = MAX(open_opps_snapshot_fact[pace_score_bucket])
		displayFolder: _open_opps_snapshot_fact
		lineageTag: ba0ef160-b133-4900-8f16-6e9b185ef9ec

	/// Compatibility measure for propensity-driven formatting in the list.
	measure 'meas.open_opps_snapshot_fact_quality_bucket' = MAX(open_opps_snapshot_fact[trueai_propensity])
		displayFolder: _open_opps_snapshot_fact
		lineageTag: 904b0b4e-e157-46ed-b648-9964e3fbde18

	/// Compatibility title measure reused by the page list visual.
	measure 'meas.open_opps_snapshot_fact_tbl_title' =
			
			"Open Opps List as of " & FORMAT([meas.cal_end_sel_date], "MM/dd/yyyy")
		displayFolder: _open_opps_snapshot_fact
		lineageTag: 3c57b76f-e590-46af-a581-ac2ea96ac353

