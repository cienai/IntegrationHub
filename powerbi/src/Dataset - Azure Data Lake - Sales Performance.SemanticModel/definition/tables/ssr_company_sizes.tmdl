/// Table ssr_company_sizes.
table ssr_company_sizes
	lineageTag: 2565960f-c84d-4fa0-b23e-0b62df0f581f

	/// Column trueai_company_size.
	column trueai_company_size
		lineageTag: 5c173858-3de0-46b8-8d1c-54065b46c2f4
		summarizeBy: none
		isNameInferred
		sourceColumn: ssr[trueai_company_size]
