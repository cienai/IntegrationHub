		lineageTag: 210cce9f-a996-4da4-96b3-cb0f3ffd2717
		summarizeBy: none
		isNameInferred
		sourceColumn: [trueai_company_size_aprox_val]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Column trueai_co_size_group.
	column trueai_co_size_group
		lineageTag: 90d5d04e-4c10-4cf8-bcb1-1ca29122d76c
		summarizeBy: none
		isNameInferred
		sourceColumn: [trueai_co_size_group]

		annotation SummarizationSetBy = Automatic

	column CompanySizeSort =
			
			SWITCH(
			    TRUE(),
			    [trueai_company_size] = "1-10 employees", 1,
			    [trueai_company_size] = "11-50 employees", 2,
			    [trueai_company_size] = "51-200 employees", 3,
			    [trueai_company_size] = "201-500 employees", 4,
			    [trueai_company_size] = "501-1,000 employees", 5,
			    [trueai_company_size] = "1,001-5,000 employees", 6,
			    [trueai_company_size] = "5,001-10,000 employees", 7,
			    [trueai_company_size] = "10,001+ employees", 8
			)
		formatString: 0
		lineageTag: fb7a934c-adfe-4ceb-8581-dd38ad0d837e
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition ssr_company_sizes = calculated
		mode: import
		source = ```
				
				SUMMARIZE(ssr,ssr[trueai_company_size],
				 "trueai_company_size_aprox_val", AVERAGE(ssr[col.trueai_company_size_aprox_val]),  
				 "trueai_co_size_group",IF(AVERAGE(ssr[col.trueai_company_size_aprox_val]) >=5000, "Enterprise", IF(AVERAGE(ssr[col.trueai_company_size_aprox_val]) >=500, "Mid-Market",IF(AVERAGE(ssr[col.trueai_company_size_aprox_val]) >=0, "SMB","ND")))
				 
				 )
				
				
				```

	annotation PBI_Id = bd04f178f3bd4d04a2e78e810ba3ef29

